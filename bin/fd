#!/usr/bin/env bash
# fd - Feishu Document Reader CLI (installed by MetaBot)
# Reads Feishu documents and wiki pages, converting them to Markdown.

set -euo pipefail

# --- Config: env vars > .env file > defaults ---
_find_env() {
  for d in "${METABOT_HOME:-}" "$HOME/feishu-claudecode" "$HOME/metabot"; do
    [[ -n "$d" && -f "$d/.env" ]] && echo "$d/.env" && return
  done
  local sd; sd="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." 2>/dev/null && pwd)"
  [[ -f "$sd/.env" ]] && echo "$sd/.env" && return
  echo ""
}
METABOT_ENV="$(_find_env)"
if [[ -n "$METABOT_ENV" && -f "$METABOT_ENV" ]]; then
  _secret=$(sed -n 's/^API_SECRET=//p' "$METABOT_ENV" 2>/dev/null || true)
  _api_port=$(sed -n 's/^API_PORT=//p' "$METABOT_ENV" 2>/dev/null || true)
fi
API_URL="${API_URL:-http://localhost:${_api_port:-9100}}"
API_SECRET="${API_SECRET:-${_secret:-}}"

_json() { python3 -m json.tool 2>/dev/null || cat; }

_curl() {
  if [[ -n "$API_SECRET" ]]; then
    curl -s -H "Authorization: Bearer $API_SECRET" "$@"
  else
    curl -s "$@"
  fi
}

# URL-encode a string
_urlencode() {
  python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$1" 2>/dev/null || echo "$1"
}

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  # Read document by URL (auto-detects docx/wiki)
  read|r)
    if [[ -z "${1:-}" ]]; then
      echo "Usage: fd read <feishu-url> [--bot <botName>]"
      exit 1
    fi
    _url="$1"; shift
    _bot=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --bot|-b) _bot="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    _encoded=$(_urlencode "$_url")
    _api="$API_URL/api/feishu/document?url=$_encoded"
    [[ -n "$_bot" ]] && _api="$_api&botName=$(_urlencode "$_bot")"
    _result=$(_curl "$_api")
    # Extract markdown field for clean output
    _md=$(echo "$_result" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('markdown',''))" 2>/dev/null)
    if [[ -n "$_md" ]]; then
      _title=$(echo "$_result" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('title',''))" 2>/dev/null)
      _wc=$(echo "$_result" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('wordCount',0))" 2>/dev/null)
      echo "# $_title"
      echo "<!-- documentId: $(echo "$_result" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('documentId',''))" 2>/dev/null) | words: $_wc -->"
      echo ""
      echo "$_md"
    else
      echo "$_result" | _json
    fi
    ;;

  # Read document by ID
  read-id|ri)
    if [[ -z "${1:-}" ]]; then
      echo "Usage: fd read-id <documentId> [--bot <botName>]"
      exit 1
    fi
    _id="$1"; shift
    _bot=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --bot|-b) _bot="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    _api="$API_URL/api/feishu/document?docId=$(_urlencode "$_id")"
    [[ -n "$_bot" ]] && _api="$_api&botName=$(_urlencode "$_bot")"
    _result=$(_curl "$_api")
    _md=$(echo "$_result" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('markdown',''))" 2>/dev/null)
    if [[ -n "$_md" ]]; then
      _title=$(echo "$_result" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('title',''))" 2>/dev/null)
      echo "# $_title"
      echo ""
      echo "$_md"
    else
      echo "$_result" | _json
    fi
    ;;

  # Get document metadata (JSON)
  info|i)
    if [[ -z "${1:-}" ]]; then
      echo "Usage: fd info <feishu-url> [--bot <botName>]"
      exit 1
    fi
    _url="$1"; shift
    _bot=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --bot|-b) _bot="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    _encoded=$(_urlencode "$_url")
    _api="$API_URL/api/feishu/document?url=$_encoded"
    [[ -n "$_bot" ]] && _api="$_api&botName=$(_urlencode "$_bot")"
    _curl "$_api" | python3 -c "
import json, sys
d = json.load(sys.stdin)
print(json.dumps({k: v for k, v in d.items() if k != 'markdown'}, indent=2))
" 2>/dev/null || _curl "$_api" | _json
    ;;

  *)
    echo "fd - Feishu Document Reader CLI"
    echo ""
    echo "  fd read <url>              Read document by Feishu URL"
    echo "  fd read-id <docId>         Read document by document ID"
    echo "  fd info <url>              Get document metadata (no content)"
    echo ""
    echo "  Options:"
    echo "    --bot <name>             Use a specific bot (default: first Feishu bot)"
    echo ""
    echo "  Supported URL formats:"
    echo "    https://xxx.feishu.cn/docx/ABC123   (standalone document)"
    echo "    https://xxx.feishu.cn/wiki/ABC123   (wiki page)"
    ;;
esac
